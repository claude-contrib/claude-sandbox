#!/bin/bash

[ -z "${DEBUG:-}" ] || set -x

set -euo pipefail

_claude_script_this="$(realpath "${BASH_SOURCE[0]}")"
_claude_script_dir="$(cd "$(dirname "$_claude_script_this")" && pwd)"

source "$_claude_script_dir/scripts/docker.sh"

# Print usage information and exit.
_show_help() {
  local version
  version="$(cat "$_claude_script_dir/version.txt" 2>/dev/null || echo "unknown")"

  cat <<EOF
claude-sandbox ${version}

Usage: claude [flags] [claude args...]

Flags:
  --sandbox       Run claude inside a Docker sandbox container
  --sandbox-help  Show this help message and exit

Claude args (intercepted in sandbox mode):
  --add-dir DIR  bind-mounted read-only into the container

Environment variables:
  CLAUDE_SANDBOX      Always run in sandbox mode (same as passing --sandbox)
  DEBUG               Enable debug tracing (set -x)

https://github.com/claude-contrib/claude-sandbox
EOF
}

# Resolve and export sandbox environment variables.
# Sets CLAUDE_DOCKER_TAG, CLAUDE_HOST_WORKING_DIR, and host user identity vars.
_resolve_docker_env() {
  CLAUDE_DOCKER_TAG="$(cat "$_claude_script_dir/version.txt")"
  CLAUDE_DOCKER_TAG="${CLAUDE_DOCKER_TAG:-latest}"
  export CLAUDE_DOCKER_TAG

  CLAUDE_HOST_UID="$(id -u)"
  CLAUDE_HOST_GID="$(id -g)"
  CLAUDE_HOST_USER="$(id -un)"
  CLAUDE_HOST_HOME="$HOME"
  CLAUDE_HOST_WORKING_DIR="$PWD"
  export CLAUDE_HOST_UID
  export CLAUDE_HOST_GID
  export CLAUDE_HOST_USER
  export CLAUDE_HOST_HOME
  export CLAUDE_HOST_WORKING_DIR

  # Validate that config paths resolve under ~/.config (the only home subdirectory
  # bind-mounted into the sandbox).
  CLAUDE_HOST_XDG_CONFIG="$HOME/.config"
  export CLAUDE_HOST_XDG_CONFIG

  # Default CLAUDE_CONFIG_DIR and GIT_CONFIG_GLOBAL to XDG paths under ~/.config.
  CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$CLAUDE_HOST_XDG_CONFIG/claude}"
  export CLAUDE_CONFIG_DIR

  CLAUDE_HOST_REPO_DIR="$(git rev-parse --git-common-dir 2>/dev/null)" || true
  # Resolve the repository root as an absolute path.
  # --git-common-dir returns a relative path (e.g. .git) in non-worktree repos,
  # so we must absolutise it before taking dirname.
  if [[ -n "$CLAUDE_HOST_REPO_DIR" ]]; then
    CLAUDE_HOST_REPO_DIR=$(dirname "$CLAUDE_HOST_REPO_DIR")
    CLAUDE_HOST_REPO_DIR="$(cd "$CLAUDE_HOST_REPO_DIR" && pwd)"
  else
    CLAUDE_HOST_REPO_DIR="$PWD"
  fi
  export CLAUDE_HOST_REPO_DIR

  if [[ "$CLAUDE_CONFIG_DIR" != "$CLAUDE_HOST_XDG_CONFIG" && "$CLAUDE_CONFIG_DIR" != "$CLAUDE_HOST_XDG_CONFIG/"* ]]; then
    gum log --level error "CLAUDE_CONFIG_DIR must be under ~/.config (got: $CLAUDE_CONFIG_DIR)"
    return 1
  fi

  GIT_CONFIG_GLOBAL="${GIT_CONFIG_GLOBAL:-$CLAUDE_HOST_XDG_CONFIG/git/config}"
  export GIT_CONFIG_GLOBAL

  if [[ "$GIT_CONFIG_GLOBAL" != "$CLAUDE_HOST_XDG_CONFIG/"* ]]; then
    gum log --level error "GIT_CONFIG_GLOBAL must be under ~/.config (got: $GIT_CONFIG_GLOBAL)"
    return 1
  fi

}

# Run claude in a Docker sandbox container.
# Builds the compose file list, detects devcontainer networks,
# and forwards SSH agent and GitHub token if available.
# Args: forwarded to the claude binary inside the container.
_run_in_docker() {
  # Verify Docker is available and running.
  if ! _check_docker; then
    gum log --level error "Docker is not running. Please start Docker and try again."
    return 1
  fi

  # Resolve and export all CLAUDE_* environment variables.
  _resolve_docker_env

  # Pull the container image if not present locally.
  _get_container_image

  local -a compose_args=()
  # Accumulate compose files
  compose_args+=(--project-name claude-sandbox)
  compose_args+=(-f "$_claude_script_dir/claude-sandbox.yml")
  compose_args+=(-f "$_claude_script_dir/claude-sandbox.env.yml")

  # Join the devcontainer's compose network when detected.
  local docker_network
  if docker_network="$(_get_container_network)"; then
    gum log --level info "Detected devcontainer network '$docker_network'"
    export CLAUDE_DOCKER_NETWORK="$docker_network"
    compose_args+=(-f "$_claude_script_dir/claude-sandbox.net.yml")
  fi

  # Forward SSH agent
  if [[ -e "${SSH_AUTH_SOCK:-}" ]]; then
    gum log --level info "Forwarding SSH agent"
    mkdir -p "$HOME/.ssh" && touch "$HOME/.ssh/known_hosts"
    compose_args+=(-f "$_claude_script_dir/claude-sandbox.ssh.yml")
  fi

  # Accumulate extra docker run options.
  local -a run_args=()
  # When stdin is a pipe: if /dev/tty is reachable, slurp piped content as the
  # last argument and reconnect stdin to the terminal so claude stays interactive.
  # If /dev/tty is unavailable (e.g. CI), disable pseudo-TTY allocation (-T).
  if ! [[ -t 0 ]]; then
    if (: </dev/tty) 2>/dev/null; then
      set -- "$@" "$(cat)"
      exec 0</dev/tty
    else
      run_args+=(-T)
    fi
  fi

  # Mount each --add-dir directory as a read-only bind volume.
  local add_dir_path
  for ((i = 1; i <= $#; i++)); do
    case "${!i}" in
    --add-dir)
      i=$((i + 1))
      add_dir_path="$(cd "${!i}" && pwd)"
      run_args+=(--volume "$add_dir_path:$add_dir_path:ro")
      ;;
    --add-dir=*)
      add_dir_path="$(cd "${!i#--add-dir=}" && pwd)"
      run_args+=(--volume "$add_dir_path:$add_dir_path:ro")
      ;;
    esac
  done

  # Launch the sandboxed claude session.
  gum log --level info "Starting Claude sandbox..."
  docker compose "${compose_args[@]}" run ${run_args[@]+"${run_args[@]}"} --rm claude claude-exec.sh "$@"
}

# Run the host claude binary, skipping this wrapper in PATH.
# Args: forwarded to the host claude binary as-is.
_run_in_host() {
  local dir entry IFS=':'

  for dir in $PATH; do
    entry="$dir/claude"
    if [[ -x "$entry" && "$(realpath "$entry")" != "$_claude_script_this" ]]; then
      "$entry" "$@"
      return
    fi
  done

  gum log --level error "Could not find host claude binary in PATH"
  exit 1
}

# Parse --sandbox flag and dispatch to docker or host exec.
# Args: all command-line arguments passed to the script.
main() {
  local run_in_docker=false
  [[ -n "${CLAUDE_SANDBOX:-}" ]] && run_in_docker=true

  local args
  args=()

  for arg in "$@"; do
    case "$arg" in
    --sandbox)
      run_in_docker=true
      ;;
    --sandbox-help)
      _show_help
      exit 0
      ;;
    *)
      args+=("$arg")
      ;;
    esac
  done

  if [[ "$run_in_docker" == true ]]; then
    _run_in_docker ${args[@]+"${args[@]}"}
  else
    _run_in_host ${args[@]+"${args[@]}"}
  fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
