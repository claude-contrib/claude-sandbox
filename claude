#!/bin/bash

[ -z "${DEBUG:-}" ] || set -x

set -euo pipefail

_claude_script_this="$(realpath "${BASH_SOURCE[0]}")"
_claude_script_dir="$(cd "$(dirname "$_claude_script_this")" && pwd)"

source "$_claude_script_dir/scripts/core.sh"
source "$_claude_script_dir/scripts/docker.sh"

# Print usage information and exit.
_show_help() {
  local version
  version="$(cat "$_claude_script_dir/version.txt" 2>/dev/null || echo "unknown")"

  cat <<EOF
claude-sandbox ${version}

Usage: claude [flags] [claude args...]

Flags:
  --sandbox    Run claude inside a Docker sandbox container
  --help       Show this help message and exit

Environment variables:
  CLAUDE_SANDBOX      Always run in sandbox mode (same as passing --sandbox)
  SSH_AUTH_SOCK       SSH agent socket (forwarded to sandbox)
  DEBUG               Enable debug tracing (set -x)

https://github.com/claude-contrib/claude-sandbox
EOF
}

# Resolve and export sandbox environment variables.
# Sets CLAUDE_DOCKER_TAG, CLAUDE_HOST_WORKING_DIR, CLAUDE_DOCKER_CONFIG_DIR,
# and CLAUDE_DOCKER_WORKING_DIR.
_resolve_docker_env() {
  CLAUDE_HOST_WORKING_DIR="$PWD"
  CLAUDE_DOCKER_TAG="$(cat "$_claude_script_dir/version.txt")"
  CLAUDE_DOCKER_TAG="${CLAUDE_DOCKER_TAG:-latest}"
  export CLAUDE_DOCKER_TAG
  export CLAUDE_HOST_WORKING_DIR

  CLAUDE_DOCKER_CONFIG_DIR=/home/claude/.config/claude
  if [[ "$CLAUDE_HOST_WORKING_DIR" == "$HOME"/* ]]; then
    CLAUDE_DOCKER_WORKING_DIR="/home/claude/${CLAUDE_HOST_WORKING_DIR#"$HOME"/}"
  else
    CLAUDE_DOCKER_WORKING_DIR="/home/claude/workspace"
  fi
  export CLAUDE_DOCKER_CONFIG_DIR
  export CLAUDE_DOCKER_WORKING_DIR
}

# Run claude in a Docker sandbox container.
# Builds the compose file list, detects devcontainer networks,
# and forwards SSH agent and GitHub token if available.
# Args: forwarded to the claude binary inside the container.
_run_in_docker() {
  # Verify Docker is available and running.
  if ! _check_docker; then
    _gum log --level error "Docker is not running. Please start Docker and try again."
    return 1
  fi

  # Resolve and export all CLAUDE_* environment variables.
  _resolve_docker_env

  # Pull the container image if not present locally.
  _get_container_image

  # Build the docker compose file list.
  CLAUDE_DOCKER_COMPOSE="$_claude_script_dir/claude-sandbox.yml"
  if [[ ! -f "$CLAUDE_DOCKER_COMPOSE" ]]; then
    _gum log --level error "Docker compose file not found: $CLAUDE_DOCKER_COMPOSE"
    return 1
  fi
  local -a docker_compose_files=(-f "$CLAUDE_DOCKER_COMPOSE")

  # Attach to a devcontainer network when detected.
  local docker_network
  if docker_network="$(_get_container_network)"; then
    _gum log --level info "Joining Docker network '$docker_network'"
    export CLAUDE_DOCKER_NETWORK="$docker_network"
    docker_compose_files+=(-f "$_claude_script_dir/claude-sandbox.net.yml")
  fi

  # Accumulate extra docker run options.
  local -a run_opts=()

  # Inject environment variables from the config file.
  local -a env_opts=()
  while IFS= read -r _env_opt; do env_opts+=("$_env_opt"); done \
    < <(_get_container_env "$_claude_script_dir/claude-sandbox.env")
  run_opts+=("${env_opts[@]+"${env_opts[@]}"}")

  if [[ -S "${SSH_AUTH_SOCK:-}" ]]; then
    CLAUDE_USER_GROUP="$(_get_container_group "$SSH_AUTH_SOCK")"
    run_opts+=(-v "$SSH_AUTH_SOCK:/run/ssh-agent" -e "SSH_AUTH_SOCK=/run/ssh-agent")
  fi

  CLAUDE_USER_GROUP="${CLAUDE_USER_GROUP:-1000}"
  export CLAUDE_USER_GROUP

  # Mount the host SSH known_hosts file (read-only).
  local _known_hosts="${HOME}/.ssh/known_hosts"
  if [[ -f "$_known_hosts" ]]; then
    run_opts+=(-v "$_known_hosts:/home/claude/.ssh/known_hosts:ro")
  fi

  # Mount the docker-specific Claude settings file (read-only).
  local claude_host_settings="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/settings.docker.json"
  if [[ -f "$claude_host_settings" ]]; then
    run_opts+=(-v "$claude_host_settings:$CLAUDE_DOCKER_CONFIG_DIR/settings.docker.json:ro")
  fi

  # When stdin is a pipe: if /dev/tty is reachable, slurp piped content as the
  # last argument and reconnect stdin to the terminal so claude stays interactive.
  # If /dev/tty is unavailable (e.g. CI), disable pseudo-TTY allocation (-T).
  if ! [[ -t 0 ]]; then
    if (: </dev/tty) 2>/dev/null; then
      set -- "$@" "$(cat)"
      exec 0</dev/tty
    else
      run_opts+=(-T)
    fi
  fi

  # Launch the sandboxed claude session.
  docker compose "${docker_compose_files[@]}" run "${run_opts[@]}" --rm claude claude-exec.sh "$@"
}

# Run the host claude binary, skipping this wrapper in PATH.
# Args: forwarded to the host claude binary as-is.
_run_in_host() {
  local dir entry IFS=':'

  for dir in $PATH; do
    entry="$dir/claude"
    if [[ -x "$entry" && "$(realpath "$entry")" != "$_claude_script_this" ]]; then
      "$entry" "$@"
      return
    fi
  done

  echo "error: could not find host claude binary in PATH" >&2
  exit 1
}

# Parse --sandbox flag and dispatch to docker or host exec.
# Args: all command-line arguments passed to the script.
main() {
  local run_in_docker=false
  [[ -n "${CLAUDE_SANDBOX:-}" ]] && run_in_docker=true

  local args
  args=()

  for arg in "$@"; do
    case "$arg" in
    --help)
      _show_help
      exit 0
      ;;
    --sandbox)
      run_in_docker=true
      ;;
    *)
      args+=("$arg")
      ;;
    esac
  done

  if [[ "$run_in_docker" == true ]]; then
    _run_in_docker ${args[@]+"${args[@]}"}
  else
    _run_in_host ${args[@]+"${args[@]}"}
  fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
